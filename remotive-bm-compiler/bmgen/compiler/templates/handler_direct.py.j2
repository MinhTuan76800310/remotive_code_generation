{% if output_groups|length > 1 %}
{# Multi-output: one restbus.update_signals() call per group. #}
async def {{ handler_name }}(self, frame: Frame) -> None:
    {{ input_signal_var }} = frame.signals["{{ input_signal_ref }}"]
{% for group in output_groups %}
    await self.{{ group.namespace_var }}.restbus.update_signals(
{% for signal in group.signals %}
        ("{{ signal.name }}", {{ signal.value_expr }}),
{% endfor %}
    )
{% endfor %}
{% else %}
{# Single-output: byte-identical to pre-multi-output rendering. #}
async def {{ handler_name }}(self, frame: Frame) -> None:
    {{ input_signal_var }} = frame.signals["{{ input_signal_ref }}"]
    await self.{{ output_namespace_var }}.restbus.update_signals(
{% for signal_name, value_expr in output_tuples %}
        ("{{ signal_name }}", {{ value_expr }}),
{% endfor %}
    )
{% endif %}